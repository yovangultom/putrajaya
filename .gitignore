# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Abaikan semua isi di folder uploads
/public/uploads/*
# Kecuali file .gitkeep dan folder projects
!/public/uploads/.gitkeep
!/public/uploads/projects/

# Abaikan semua isi di dalam folder projects
/public/uploads/projects/*
# Kecuali file .gitkeep milik folder projects
!/public/uploads/projects/.gitkeep
