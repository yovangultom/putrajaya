
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  signatureUrl  String?   
  role          String    @default("EDITOR") 
  accounts      Account[]
  sessions      Session[]
  projects      Project[] 
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model Project {
  id              String        @id @default(cuid())
  title           String        
  
  clientName      String        
  clientCompany   String?       
  clientPhone     String?       
  clientAddress   String?       
  projectLocation String        

  status          String        @default("PENGAJUAN") 
  dpAmount        Float         @default(0) 
  startDate       DateTime?     
  endDate         DateTime?     
  actualEndDate   DateTime?     


  pengajuanItems  PengajuanItem[] 
  bap             Bap?            
  invoice         Invoice?        

  expenses        ProjectExpense[]

  userId          String
  user            User          @relation(fields: [userId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PengajuanItem {
  id          String  @id @default(cuid())
  description String  
  qty         Float   
  unit        String  
  price       Float   
  
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Bap {
  id          String   @id @default(cuid())
  bapNumber   String   @unique  
  date        DateTime @default(now())
  notes       String?  

  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  items       BapItem[]       
  attachments BapAttachment[] 
}

model BapItem {
  id          String  @id @default(cuid())
  description String  
  qty         Float
  unit        String
  price       Float   
  
  bapId       String
  bap         Bap     @relation(fields: [bapId], references: [id], onDelete: Cascade)
}

model BapAttachment {
  id          String  @id @default(cuid())
  imageUrl    String  
  description String  
  
  bapId       String
  bap         Bap     @relation(fields: [bapId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique 
  date          DateTime @default(now())
  dueDate       DateTime? 
  terbilang     String   

  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DocumentCounter {
  id          String  @id @default(cuid())
  year        Int     
  type        String  
  lastNumber  Int     @default(0) 

  @@unique([year, type])
}

model ProjectExpense {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String   
  amount      Float    
  date        DateTime @default(now()) 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Worker {
  id                  String       @id @default(cuid())
  name                String
  role                String       
  dailyWage           Float        
  overtimeRatePerHour Float        @default(0) 
  
  attendances         Attendance[]
  payslips            Payslip[]
  
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Attendance {
  id            String    @id @default(cuid())
  workerId      String
  worker        Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  date          DateTime  @default(now()) 
  
  // 1 = Hadir Penuh, 0.5 = Setengah Hari, 0 = Tidak Hadir/Izin
  status        Float     @default(1.0) 
  
  overtimeHours Float     @default(0) 
  
  notes         String?   
  
  createdAt     DateTime  @default(now())
}

model Payslip {
  id              String   @id @default(cuid())
  workerId        String
  worker          Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  periodStart     DateTime 
  periodEnd       DateTime 
  
  totalDays       Float    
  totalOvertime   Float    
  
  bonus           Float    @default(0) 
  kasbonDeduction Float    @default(0) 
  
  netPay          Float    
  
  createdAt       DateTime @default(now())
}

model CompanyExpense {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Portfolio {
  id             String             @id @default(cuid())
  title          String
  slug           String             @unique
  client         String
  location       String
  category       String
  completionDate DateTime
  image          String             
  description    String
  createdAt      DateTime           @default(now())
  
  gallery        PortfolioGallery[] 
}

model PortfolioGallery {
  id          String    @id @default(cuid())
  imageUrl    String
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model CompanyIncome {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}