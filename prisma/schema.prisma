// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. MANAJEMEN USER & AUTH (NEXTAUTH)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  signatureUrl  String?   // <-- Untuk simpan Tanda Tangan Digital Internal
  role          String    @default("EDITOR") // Diubah dari enum ke String
  accounts      Account[]
  sessions      Session[]
  projects      Project[] // Relasi pembuat proyek
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? // Hapus @db.Text
  access_token      String? // Hapus @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? // Hapus @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 2. ALUR KERJA UTAMA (TAHAP 1 - 6)
// ==========================================

model Project {
  id              String        @id @default(cuid())
  title           String        // Judul Pekerjaan
  
  // Data Klien (Dari Formulir Pemberi Kerja)
  clientName      String        
  clientCompany   String?       
  clientPhone     String?       
  clientAddress   String?       // Hapus @db.Text
  projectLocation String        // Hapus @db.Text

  // Status & Pembayaran Awal
  status          String        @default("PENGAJUAN") // Diubah dari enum ke String
  dpAmount        Float         @default(0) // Down Payment dicatat saat Deal
  startDate       DateTime?     // Jadwal mulai pengerjaan
  endDate         DateTime?     // Jadwal selesai pengerjaan
  actualEndDate   DateTime?     // Tanggal asli selesai (otomatis terisi saat BAP)


  // Relasi ke Dokumen Lain
  pengajuanItems  PengajuanItem[] // Tabel Rincian Pengajuan Awal
  bap             Bap?            // Berita Acara & Lampiran
  invoice         Invoice?        // Tagihan Final

  expenses        ProjectExpense[]

  // Audit Trail
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// --- TAHAP 1: PENGAJUAN AWAL ---
model PengajuanItem {
  id          String  @id @default(cuid())
  description String  // Contoh: Coring Lantai 4"
  qty         Float   // Pake Float karena bisa saja volumenya koma
  unit        String  // Contoh: titik, ls
  price       Float   // Harga Satuan Estimasi Awal
  
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// --- TAHAP 5A: BERITA ACARA (BAP) ---
model Bap {
  id          String   @id @default(cuid())
  bapNumber   String   @unique  // Auto: 001/BAP/PJ/IV/2026
  date        DateTime @default(now())
  notes       String?  // Hapus @db.Text

  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  items       BapItem[]       // Rincian Aktual (Input harga baru di sini)
  attachments BapAttachment[] // Lampiran Foto
}

model BapItem {
  id          String  @id @default(cuid())
  description String  // Contoh: Penambahan Coring D = 5"
  qty         Float
  unit        String
  price       Float   // Harga Satuan Aktual untuk Invoice
  
  bapId       String
  bap         Bap     @relation(fields: [bapId], references: [id], onDelete: Cascade)
}

model BapAttachment {
  id          String  @id @default(cuid())
  imageUrl    String  // Path folder lokal: /uploads/foto-1.jpg
  description String  // Contoh: Proses Pekerjaan Coring
  
  bapId       String
  bap         Bap     @relation(fields: [bapId], references: [id], onDelete: Cascade)
}

// --- TAHAP 5B & 6: INVOICE ---
model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique // Auto: 001/INV/PJ/IV/2026
  date          DateTime @default(now())
  dueDate       DateTime? // Tenggat Waktu Pembayaran
  terbilang     String   // Teks: "Satu Juta Rupiah"

  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// --- TABEL SISTEM (UNTUK PENOMORAN OTOMATIS) ---
model DocumentCounter {
  id          String  @id @default(cuid())
  year        Int     // Contoh: 2026
  type        String  // Diubah dari enum ke String (BAP atau INVOICE)
  lastNumber  Int     @default(0) // Angka terakhir yg digunakan (misal 5)

  @@unique([year, type])
}

model ProjectExpense {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String   // Contoh: "Bensin operasional", "Kopi & Makan Tukang"
  amount      Float    // Nominal pengeluaran, contoh: 50000
  date        DateTime @default(now()) // Tanggal pengeluaran dicatat
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// SISTEM HR & PAYROLL (ABSENSI & GAJI)
// ==========================================

// 1. DATA PEKERJA UTAMA
model Worker {
  id                  String       @id @default(cuid())
  name                String
  role                String       // Contoh: Mandor, Tukang Besi, Kenek
  dailyWage           Float        // Gaji pokok per 1 hari kerja (Full Day)
  overtimeRatePerHour Float        @default(0) // Upah lembur per jam
  
  // Relasi: 1 Pekerja punya banyak riwayat absensi dan slip gaji
  attendances         Attendance[]
  payslips            Payslip[]
  
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

// 2. DATA ABSENSI HARIAN
model Attendance {
  id            String    @id @default(cuid())
  workerId      String
  worker        Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  date          DateTime  @default(now()) // Tanggal absensi dicatat
  
  // 1 = Hadir Penuh, 0.5 = Setengah Hari, 0 = Tidak Hadir/Izin
  status        Float     @default(1.0) 
  
  overtimeHours Float     @default(0) // Jumlah jam lembur di hari tersebut
  
  notes         String?   // Catatan tambahan (opsional)
  
  createdAt     DateTime  @default(now())
}

// 3. DATA SLIP GAJI MINGGUAN
model Payslip {
  id              String   @id @default(cuid())
  workerId        String
  worker          Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  // Periode Mingguan (Contoh: 1 April - 6 April)
  periodStart     DateTime 
  periodEnd       DateTime 
  
  // Rekapan dari Absensi
  totalDays       Float    // Total hari kerja (misal: 5.5 hari)
  totalOvertime   Float    // Total jam lembur seminggu
  
  // Variabel Penambah/Pengurang
  bonus           Float    @default(0) // Uang tambahan/kerajinan
  kasbonDeduction Float    @default(0) // Potongan utang kasbon minggu ini
  
  // Hasil Akhir (Take Home Pay)
  netPay          Float    // Gaji bersih yang dicairkan
  
  createdAt       DateTime @default(now())
}

model CompanyExpense {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}